# EAMI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to source control.

# ─────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────

# Password for the eami_app database user. Required — the app and the
# postgres container both refuse to start if this is unset or a known
# placeholder ("changeme"/"devpassword").
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=

# Full connection URL (used by seed-db.sh and application services).
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# Use the same password as POSTGRES_PASSWORD above.
DATABASE_URL=

# ─────────────────────────────────────────────────────────
# eami-collector
# ─────────────────────────────────────────────────────────

# Port the on-prem collector listens on (agents POST reports here).
COLLECTOR_PORT=8888

# URL that endpoint agents use to reach the collector.
# In production: https://collector.corp.internal:8888
COLLECTOR_URL=http://localhost:8888

# API key used by endpoint agents to authenticate with the collector.
# Generate: openssl rand -hex 32  (setup.sh generates this automatically)
COLLECTOR_API_KEY=

# Path inside the collector container for the SQLite buffer DB.
# (Usually left at default; change only for custom volume mounts.)
COLLECTOR_BUFFER_DB_PATH=/data/buffer.db

# URL that the collector forwards batched data to (the SaaS API).
COLLECTOR_SAAS_URL=http://eami-api:8081

# ─────────────────────────────────────────────────────────
# eami-gateway
# ─────────────────────────────────────────────────────────

# Port for the gateway REST management API.
GATEWAY_API_PORT=8080

# Port for the MCP SSE transport (AI agents connect here).
GATEWAY_MCP_SSE_PORT=3000

# Serf gossip port (mesh communication between gateway nodes).
GATEWAY_GOSSIP_PORT=7946

# Path to the RSA private key used to sign AI tokens (JWT RS256).
# Generate: openssl genrsa -out gateway.key 2048
GATEWAY_JWT_KEY_PATH=/certs/gateway.key

# Slack webhook for approval notifications (optional — approvals work without it, just no Slack message).
# Create at: https://api.slack.com/apps → Incoming Webhooks
GATEWAY_APPROVAL_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: enable pprof listener on the gateway for profiling / load-test goroutine sampling.
# Set to ":6060" to enable. Leave empty (default) in production — do not expose to public internet.
GATEWAY_PPROF_ADDR=

# The public URL of your EAMI UI — used in Slack approval links so reviewers can click through.
GATEWAY_UI_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────
# eami-api (SaaS REST API backend)
# ─────────────────────────────────────────────────────────

# Port the API server listens on.
API_PORT=8081

# JWT signing secret for user session tokens (HS256 fallback; prefer RS256 in prod).
# Generate: openssl rand -base64 32
API_JWT_SECRET=dev-jwt-secret-change-in-prod

# Shared service key for internal gateway → API authentication. Required —
# both eami-api and eami-gateway refuse to start if this is unset or a known
# placeholder ("changeme"). Both values must be identical.
# Generate: openssl rand -hex 32
API_SERVICE_KEY=
GATEWAY_API_SERVICE_KEY=

# Dedicated secret for eami-api -> eami-gateway calls to the episode read
# endpoint (full episode/tool-call content, on-prem only per ADR-019/
# ADR-010). Deliberately separate from GATEWAY_API_SERVICE_KEY above
# (different direction, different blast radius on leak). Read by BOTH
# services from this one value: required on eami-gateway (refuses to start
# if empty) and optional on eami-api (the proxy routes added in B-002 Brief 2
# just 502 per-request if unset — eami-api itself still starts fine).
# Generate: openssl rand -hex 32
GATEWAY_EPISODE_READ_SERVICE_KEY=

# Base URL eami-api uses to reach eami-gateway's episode read endpoint
# (B-002 Brief 2). Optional — the gateway proxy routes 502 if unset.
API_GATEWAY_URL=http://localhost:8080

# AES-256 key (hex-encoded, 32 bytes) used by eami-api to encrypt gateway
# tool credentials (api_key/oauth secrets/DB connection strings submitted
# via Tools → Add Tool) before they are written to
# gateway_tools.credentials_encrypted. Encryption happens in the API
# process — this key never reaches Postgres. Required for POST
# /v1/gateway/tools to accept a `credentials` payload; tool creation
# without credentials works fine if this is unset. Losing this key makes
# any already-stored credentials unrecoverable — treat it like
# POSTGRES_PASSWORD, not like a rotatable API key.
# Generate: openssl rand -hex 32
TOOL_CREDENTIALS_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────
# eami-ui (React frontend)
# ─────────────────────────────────────────────────────────

# URL that the browser uses to reach eami-api.
VITE_API_URL=http://localhost:8081

# URL that the browser uses to reach eami-gateway management API.
VITE_GATEWAY_URL=http://localhost:8080
